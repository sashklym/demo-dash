# Copy to .env for local development: cp .env.sample .env
NODE_ENV=development

# HTTP
PORT=3000
HOST=0.0.0.0

# SQLite database file (created on first run)
DATABASE_PATH=./data/youscan.sqlite

# Logging: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# CORS: "*" for any origin, or a comma-separated allowlist
# e.g. CORS_ORIGIN=http://localhost:5173,https://dashboard.example.com
CORS_ORIGIN=*
